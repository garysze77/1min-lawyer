# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# MiniMax API (for AI Analysis Edge Function)
# Set this secret in Supabase dashboard: Edge Functions >Secrets
MINIMAX_API_KEY=your-minimax-api-key

# Telegram Bot (for admin notifications - OPTIONAL)
# Create bot via @BotFather, get token, then set secret in Supabase
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id
